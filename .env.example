# Root .env — used by Docker Compose for build-time variable interpolation.
#
# These variables are read by compose when it processes docker-compose.yml
# (e.g., for the mysql service's MYSQL_* environment block). They must match
# the values inside apps/web/.env so the database credentials are consistent.
#
# Copy this to .env and fill in your values:
#   cp .env.example .env

DB_URL=mysql://vectorops:vectorops@127.0.0.1:3308/vectorops
DB_NAME=vectorops
DB_USER=vectorops
DB_PASSWORD=vectorops
DB_HOST=127.0.0.1
DB_PORT=3308