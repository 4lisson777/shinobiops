generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  TECH_LEAD
  DEVELOPER
  SUPPORT_LEAD
  SUPPORT_MEMBER
  QA
}

enum TicketType {
  TICKET
  BUG
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_INFO
  DONE
  CANCELLED
}

enum Environment {
  PRODUCTION
  STAGING
  OTHER
}

enum TicketEventType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  REASSIGNED
  SEVERITY_CHANGED
  DEADLINE_CHANGED
  PRIORITY_REORDERED
  REORDER_REQUESTED
  REORDER_APPROVED
  REORDER_DECLINED
  HELP_REQUESTED
  CHECKPOINT_MENTION
  DONE
  CANCELLED
}

enum ReorderStatus {
  PENDING
  APPROVED
  DECLINED
}

enum DevStatus {
  ACTIVE
  IN_CHECKPOINT
  BLOCKED
  HELPING
}

enum NotificationType {
  TICKET_CREATED
  BUG_CREATED
  TICKET_ASSIGNED
  TICKET_STATUS_CHANGED
  TICKET_DONE
  TICKET_CANCELLED
  HELP_REQUEST_NEW
  HELP_REQUEST_RESPONDED
  CHECKPOINT_PROMPT
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  tickets                Ticket[]
  notifications          Notification[]
  helpRequests           HelpRequest[]
  helpRequestResponses   HelpRequestResponse[]
  checkpoints            Checkpoint[]
  checkpointConfigs      CheckpointConfig[]
  tvConfigs              TvConfig[]
  roleNotificationConfigs RoleNotificationConfig[]
  invites                Invite[]

  @@map("organizations")
}

model Invite {
  id             String    @id @default(cuid())
  organizationId String
  code           String    @unique
  role           Role
  email          String?
  expiresAt      DateTime
  usedById       String?
  usedAt         DateTime?
  createdById    String
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  usedBy       User?        @relation("UsedInvites", fields: [usedById], references: [id])
  createdBy    User         @relation("CreatedInvites", fields: [createdById], references: [id])

  @@map("invites")
}

model User {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  email          String
  passwordHash   String
  role           Role
  avatarUrl      String?
  ninjaAlias     String
  isActive       Boolean    @default(true)
  isSuperAdmin   Boolean    @default(false)
  notifyTickets  Boolean    @default(true)
  notifyBugs     Boolean    @default(true)
  soundEnabled   Boolean    @default(true)
  devStatus      DevStatus? @default(ACTIVE)
  currentTask    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  openedTickets     Ticket[]              @relation("OpenedTickets")
  assignedTickets   Ticket[]              @relation("AssignedTickets")
  actorEvents       TicketEvent[]         @relation("ActorEvents")
  requestedReorders ReorderRequest[]      @relation("RequestedReorders")
  resolvedReorders  ReorderRequest[]      @relation("ResolvedReorders")
  notifications     Notification[]
  requestedHelp     HelpRequest[]         @relation("RequestedHelp")
  helpResponses     HelpRequestResponse[] @relation("RespondedHelp")
  checkpoints       Checkpoint[]
  usedInvites       Invite[]              @relation("UsedInvites")
  createdInvites    Invite[]              @relation("CreatedInvites")

  @@unique([organizationId, email])
  @@map("users")
}

model Ticket {
  id             String       @id @default(cuid())
  organizationId String
  publicId       String       @unique
  title          String
  description    String
  type           TicketType
  severity       Severity
  status         TicketStatus @default(OPEN)
  deadline       DateTime
  priorityOrder  Int
  openedById     String
  assignedToId   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  resolvedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  openedBy     User         @relation("OpenedTickets", fields: [openedById], references: [id])
  assignedTo   User?         @relation("AssignedTickets", fields: [assignedToId], references: [id])

  bugReport       BugReport?
  events          TicketEvent[]
  reorderRequests ReorderRequest[]
  notifications   Notification[]

  @@index([organizationId])
  @@index([openedById])
  @@index([assignedToId])
  @@map("tickets")
}

model BugReport {
  id               String      @id @default(cuid())
  ticketId         String      @unique
  affectedModule   String
  stepsToReproduce String
  expectedBehavior String
  actualBehavior   String
  environment      Environment
  customerId       String?

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("bug_reports")
}

model TicketEvent {
  id        String          @id @default(cuid())
  ticketId  String
  eventType TicketEventType
  actorId   String
  metadata  String          @default("{}")
  createdAt DateTime        @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User   @relation("ActorEvents", fields: [actorId], references: [id])

  @@index([ticketId])
  @@map("ticket_events")
}

model ReorderRequest {
  id                String        @id @default(cuid())
  ticketId          String
  requestedById     String
  requestedPosition Int
  reason            String?
  status            ReorderStatus @default(PENDING)
  resolvedById      String?
  resolvedAt        DateTime?
  createdAt         DateTime      @default(now())

  ticket      Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  requestedBy User   @relation("RequestedReorders", fields: [requestedById], references: [id])
  resolvedBy  User?  @relation("ResolvedReorders", fields: [resolvedById], references: [id])

  @@map("reorder_requests")
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String
  body           String
  ticketId       String?
  isRead         Boolean          @default(false)
  requiresAck    Boolean          @default(false)
  acknowledgedAt DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket       Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, requiresAck, acknowledgedAt])
  @@map("notifications")
}

model HelpRequest {
  id             String   @id @default(cuid())
  organizationId String
  requestedById  String
  contextMessage String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  requestedBy  User         @relation("RequestedHelp", fields: [requestedById], references: [id])
  responses    HelpRequestResponse[]

  @@index([organizationId])
  @@index([requestedById])
  @@map("help_requests")
}

model HelpRequestResponse {
  id             String   @id @default(cuid())
  organizationId String
  helpRequestId  String
  responderId    String
  respondedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  helpRequest  HelpRequest  @relation(fields: [helpRequestId], references: [id], onDelete: Cascade)
  responder    User          @relation("RespondedHelp", fields: [responderId], references: [id])

  @@map("help_request_responses")
}

model Checkpoint {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  currentTask    String
  isBlocked      Boolean
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId, createdAt])
  @@map("checkpoints")
}

model CheckpointConfig {
  id               String  @id @default(cuid())
  organizationId   String  @unique
  intervalMinutes  Int     @default(60)
  activeHoursStart String  @default("09:00")
  activeHoursEnd   String  @default("18:00")
  isEnabled        Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("checkpoint_config")
}

model TvConfig {
  id              String  @id @default(cuid())
  organizationId  String  @unique
  isEnabled       Boolean @default(true)
  refreshInterval Int     @default(30)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("tv_config")
}

model RoleNotificationConfig {
  id                  String   @id @default(cuid())
  organizationId      String
  role                Role
  notifyOnCreation    Boolean  @default(false)
  notifyOnAssignment  Boolean  @default(false)
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, role])
  @@map("role_notification_configs")
}
