    "@workspace/ui": "*",
    "bcryptjs": "^2.4.3",
    "iron-session": "^8.0.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
