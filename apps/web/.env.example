# Copy this file to .env and fill in the values before running the app.

# SQLite database file path (relative to apps/web)
DATABASE_URL=file:./prisma/data/shinobiops.db

# iron-session encryption secret — must be at least 32 characters long.
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-character-string-minimum

# Node environment
NODE_ENV=development
