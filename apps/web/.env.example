# iron-session encryption secret — must be at least 32 characters long.
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-character-string-minimum

# Database connection — used at runtime by `prisma migrate deploy` and by the
# entrypoint health probe.
#
#   Local development: host is localhost (or 127.0.0.1), port 3308 if you use
#   the docker-compose MySQL service exposed on that port, or 3306 for a native install.
#
#   Docker (production): host MUST be the compose service name "mysql", port 3306.
#   This file is injected into the container via `env_file: apps/web/.env` in
#   docker-compose.yml, so these values become the live runtime credentials.
DB_URL=mysql://vectorops:vectorops@localhost:3308/vectorops

# Individual connection fields used by lib/db.ts (PrismaMariaDb adapter) and
# by the MySQL compose service (MYSQL_* vars).
DB_HOST=localhost
DB_PORT=3308
DB_NAME=vectorops
DB_USER=vectorops
DB_PASSWORD=vectorops

# Node environment
NODE_ENV=development

# Production seed — required only when running `npm run db:seed:prod`
# These create the VectorOps organization and the initial super admin account.
SEED_ADMIN_NAME=Your Name
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=ChangeMe123!
